{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noEmit": true,
    "incremental": true,
    "jsx": "preserve",
    "forceConsistentCasingInFileNames": true,
    "verbatimModuleSyntax": false,
    "paths": {
      "@easyfest/db": ["./packages/db/src/index.ts"],
      "@easyfest/db/*": ["./packages/db/src/*"],
      "@easyfest/ui": ["./packages/ui/src/index.ts"],
      "@easyfest/ui/*": ["./packages/ui/src/*"],
      "@easyfest/shared": ["./packages/shared/src/index.ts"],
      "@easyfest/shared/*": ["./packages/shared/src/*"]
    }
  },
  "exclude": ["node_modules", ".next", "dist", "build", ".turbo", "coverage"]
}
