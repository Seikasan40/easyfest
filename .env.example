# ─────────────────────────────────────────────────────────────────────
# EASYFEST — variables d'environnement (v2 — Hermes patch 29/04 23:50)
# Aucune valeur réelle dans le repo. Vault Netlify pour la production.
# Vault GitHub Actions pour le CI. .env.local en dev (gitignored).
# ─────────────────────────────────────────────────────────────────────

# ════════════════════════════════════════════════════════════════════
# 1. APP META — public, OK dans le repo
# ════════════════════════════════════════════════════════════════════
NEXT_PUBLIC_APP_NAME="Easyfest"
NEXT_PUBLIC_APP_URL="https://easyfest.app"
NEXT_PUBLIC_VITRINE_URL="https://easyfest.app"
NEXT_PUBLIC_ADMIN_URL="https://easyfest.app/admin"
NEXT_PUBLIC_DEFAULT_LOCALE="fr"
NEXT_PUBLIC_DEFAULT_TIMEZONE="Europe/Paris"

# ════════════════════════════════════════════════════════════════════
# 2. SUPABASE — backend principal (région eu-west-3 paris OBLIGATOIRE)
# ════════════════════════════════════════════════════════════════════
NEXT_PUBLIC_SUPABASE_URL="https://xxxxxxxxxxxxxxxxxxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGc...ANON_KEY...XXX"
SUPABASE_SERVICE_ROLE_KEY="eyJhbGc...SERVICE_ROLE...XXX"
SUPABASE_JWT_SECRET="super-secret-jwt-string-from-supabase-settings"
SUPABASE_PROJECT_REF="xxxxxxxxxxxxxxxxxxxx"
SUPABASE_DB_URL="postgresql://postgres:[PASSWORD]@db.xxxxxxxxxxxxxxxxxxxx.supabase.co:5432/postgres"
SUPABASE_DB_URL_POOLED="postgresql://postgres:[PASSWORD]@db.xxxxxxxxxxxxxxxxxxxx.supabase.co:6543/postgres?pgbouncer=true"
SUPABASE_DB_PASSWORD="strong-random-password"
EXPO_PUBLIC_SUPABASE_URL="https://xxxxxxxxxxxxxxxxxxxx.supabase.co"
EXPO_PUBLIC_SUPABASE_ANON_KEY="eyJhbGc...ANON_KEY...XXX"

# ════════════════════════════════════════════════════════════════════
# 3. QR CODE SIGNATURE — HMAC SHA-256 (rotation 6 mois)
# Génération : openssl rand -hex 64
# ════════════════════════════════════════════════════════════════════
QR_HMAC_SECRET="generate-with-openssl-rand-hex-64-replace-this-very-long-string"
QR_TOKEN_TTL_SECONDS="600"  # 10 min de validité par scan token

# ════════════════════════════════════════════════════════════════════
# 3.5. SENTRY (OC-06+07) — error tracking + sourcemaps upload
# DSN public OK ; AUTH_TOKEN secret CI uniquement.
# Tout no-op si DSN absente (dev local sans projet Sentry).
# ════════════════════════════════════════════════════════════════════
NEXT_PUBLIC_SENTRY_DSN=""                # https://xxx@xxx.ingest.sentry.io/xxx
SENTRY_DSN=""                            # idem (init server-side runtime non-Next)
SENTRY_ORG=""                            # slug Sentry org
SENTRY_PROJECT=""                        # slug Sentry project (ex: easyfest-vitrine)
SENTRY_AUTH_TOKEN=""                     # SECRET — token upload sourcemaps (CI only)

# ════════════════════════════════════════════════════════════════════
# 3.6. POSTHOG (OC-06+07) — analytics opt-in via cookie banner EU
# ════════════════════════════════════════════════════════════════════
NEXT_PUBLIC_POSTHOG_KEY=""               # phc_xxxxx (clé publique projet)
NEXT_PUBLIC_POSTHOG_HOST="https://eu.i.posthog.com"

# ════════════════════════════════════════════════════════════════════
# 4. RESEND — mail transactionnel (DKIM/SPF sur easyfest.app dès J0)
# ════════════════════════════════════════════════════════════════════
RESEND_API_KEY="re_xxxxxxxx_xxxxxxxxxxxxxxxxxxxxx"
RESEND_FROM_EMAIL="hello@easyfest.app"
RESEND_REPLY_TO="contact@easyfest.app"
RESEND_TEMPLATE_VALIDATION_ID="xxxx"
RESEND_TEMPLATE_REJECTION_ID="xxxx"
RESEND_TEMPLATE_MAGIC_LINK_ID="xxxx"
RESEND_TEMPLATE_SAFER_ALERT_ID="xxxx"

# ════════════════════════════════════════════════════════════════════
# 5. CLOUDFLARE TURNSTILE — anti-bot formulaire signup
# ════════════════════════════════════════════════════════════════════
NEXT_PUBLIC_TURNSTILE_SITE_KEY="0x4AAAAAAA_XXXXXXXXX"
TURNSTILE_SECRET_KEY="0x4AAAAAAA_XXXXXXXXX_secret"

# ════════════════════════════════════════════════════════════════════
# 6. MAPBOX — carte du site festival (Token public restreint domaine)
# ════════════════════════════════════════════════════════════════════
NEXT_PUBLIC_MAPBOX_TOKEN="pk.eyJ1IjoieHh4...mapbox-public-token"
EXPO_PUBLIC_MAPBOX_TOKEN="pk.eyJ1IjoieHh4...mapbox-public-token"

# ════════════════════════════════════════════════════════════════════
# 7. SENTRY — error tracking (3 projets : web, edge, mobile)
# ════════════════════════════════════════════════════════════════════
NEXT_PUBLIC_SENTRY_DSN_WEB="https://xxxxxxxxxxx@sentry.io/xxxxxxx"
SENTRY_DSN_EDGE="https://xxxxxxxxxxx@sentry.io/xxxxxxx"
EXPO_PUBLIC_SENTRY_DSN_MOBILE="https://xxxxxxxxxxx@sentry.io/xxxxxxx"
SENTRY_ORG="easyfest"
SENTRY_AUTH_TOKEN="sntrys_xxxxxxxxx"
SENTRY_PROJECT_WEB="easyfest-web"
SENTRY_PROJECT_MOBILE="easyfest-mobile"

# ════════════════════════════════════════════════════════════════════
# 8. POSTHOG — product analytics (cloud EU)
# ════════════════════════════════════════════════════════════════════
NEXT_PUBLIC_POSTHOG_KEY="phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
NEXT_PUBLIC_POSTHOG_HOST="https://eu.i.posthog.com"
EXPO_PUBLIC_POSTHOG_KEY="phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ════════════════════════════════════════════════════════════════════
# 9. NETLIFY — hébergement vitrine + admin Next.js
# ════════════════════════════════════════════════════════════════════
NETLIFY_SITE_ID="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
NETLIFY_AUTH_TOKEN="nfp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
NETLIFY_FUNCTIONS_REGION="eu-west-1"

# ════════════════════════════════════════════════════════════════════
# 10. EXPO / EAS — builds mobile (APK Android only en V1)
# ════════════════════════════════════════════════════════════════════
EAS_PROJECT_ID="00000000-0000-0000-0000-000000000000"
EXPO_TOKEN="xxxxx_used_in_CI_for_eas_build"
ANDROID_KEYSTORE_BASE64=""
ANDROID_KEYSTORE_PASSWORD=""
ANDROID_KEY_ALIAS=""
ANDROID_KEY_PASSWORD=""

# ════════════════════════════════════════════════════════════════════
# 11. TWILIO — SMS (V2 placeholder)
# ════════════════════════════════════════════════════════════════════
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""
TWILIO_MESSAGING_SERVICE_SID=""

# ════════════════════════════════════════════════════════════════════
# 12. STRIPE — billetterie V2 placeholder
# ════════════════════════════════════════════════════════════════════
STRIPE_PUBLIC_KEY=""
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_CONNECT_CLIENT_ID=""

# ════════════════════════════════════════════════════════════════════
# 13. CRON / SCHEDULER
# ════════════════════════════════════════════════════════════════════
CRON_SECRET="generate-with-openssl-rand-hex-32"

# ════════════════════════════════════════════════════════════════════
# 14. RGPD / SECURITY
# ════════════════════════════════════════════════════════════════════
RGPD_PURGE_DELAY_MONTHS="12"
DPA_SIGNED_DATE="2026-04-29"
DPA_SUB_PROCESSORS_URL="https://easyfest.app/legal/sub-processors"
DEFAULT_BAN_REQUIRED_APPROVALS="3"
PRIVACY_POLICY_VERSION="1.0.0"
COOKIE_BANNER_REQUIRED="true"
PII_SCRUB_FIELDS="phone,email,birth_date,address_street,address_city,address_zip,diet_notes,parental_auth_url"

# ════════════════════════════════════════════════════════════════════
# 15. OPS / SAFETY
# ════════════════════════════════════════════════════════════════════
MAINTENANCE_MODE="false"
EMERGENCY_ROUTING_NUMBER="+33112"
LOG_LEVEL="info"
MAX_VOLUNTEERS_PER_EVENT_FREE="100"
MAX_VOLUNTEERS_PER_EVENT_CREW="500"
MAX_VOLUNTEERS_PER_EVENT_FESTIVAL="2000"
ANALYTICS_OPT_OUT_DEFAULT="true"

# ════════════════════════════════════════════════════════════════════
# 16. FEATURE FLAGS — toggles par environnement
# ════════════════════════════════════════════════════════════════════
FEATURE_BILLETTERIE="false"
FEATURE_CASHLESS="false"
FEATURE_SPONSORS_CRM="false"
FEATURE_AI_COPILOT="false"
FEATURE_MEDIATORS="true"
FEATURE_OFFLINE_PWA="false"        # true à partir du 12 mai
FEATURE_MFA_TOTP="false"           # true à partir du 15 juin (RDL post-mortem)
FEATURE_SAFER_SPACE_V0="true"
FEATURE_QR_SCAN_LIVE="false"       # true à partir du 27 mai (J-1 RDL)
FEATURE_REALTIME="false"

# ════════════════════════════════════════════════════════════════════
# 17. DEV / DEBUG
# ════════════════════════════════════════════════════════════════════
NODE_ENV="development"
NEXT_TELEMETRY_DISABLED="1"
DEBUG_RLS="false"

# ─────────────────────────────────────────────────────────────────────
# CHECKLIST AVANT COMMIT :
#   1. Toutes les *_PUBLIC_* / EXPO_PUBLIC_* sont safe à exposer client.
#   2. SUPABASE_SERVICE_ROLE_KEY + QR_HMAC_SECRET = JAMAIS dans bundle client.
#      grep -rn "SUPABASE_SERVICE_ROLE_KEY\|QR_HMAC_SECRET" apps/*/.next
#      → doit retourner ZÉRO match.
#   3. Tous les secrets en prod : Netlify Vault + EAS Secrets + GH Secrets.
# ─────────────────────────────────────────────────────────────────────
